  "keyFeatures": [
    "Local-first Markdown note-taking with no vendor lock-in",
    "Bidirectional linking between notes with backlinks and graph view",
    "Bases: database-like views of notes using properties",
    "Canvas: infinite whiteboard for visual thinking",
    "Obsidian Sync: end-to-end encrypted cross-device sync",
    "Obsidian Publish: host notes as a public website",
    "Rich plugin ecosystem with 1000+ community plugins",
    "Obsidian URI protocol for automation and cross-app workflows",
    "Obsidian CLI for terminal-based control",
    "Fully offline capable with optional cloud services"
  ],
  "publicApiSurface": [
    "obsidian://open — open a vault or note via URI",
    "obsidian://new — create a new note via URI",
    "obsidian://daily — open or create daily note via URI",
    "obsidian://search — open search in a vault via URI",
    "obsidian://choose-vault — open vault manager via URI",
    "obsidian://hook-get-address — Hook productivity integration",
    "Obsidian CLI (obsidian-cli) — command-line control of Obsidian",
    "Community Plugin API — extend Obsidian with custom plugins",
    "CSS snippets & themes — customize appearance",
    "Bases syntax (.base files) — define database-like views in Markdown"
  ]
